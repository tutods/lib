{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "linter": {
    "domains": {
      "next": "recommended"
    }
  },
  "overrides": [
    {
      "includes": [
        "**/src/app/**/page.tsx",
        "**/src/app/**/layout.tsx",
        "**/src/app/**/loading.tsx",
        "**/src/app/**/error.tsx",
        "**/src/app/**/not-found.tsx",
        "**/src/app/**/template.tsx",
        "**/src/app/**/default.tsx",
        "**/src/app/**/route.ts",
        "**/src/app/**/route.tsx",
        "**/src/middleware.ts",
        "**/app/api/**/*.{js,jsx,ts,tsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
