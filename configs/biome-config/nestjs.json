{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "linter": {
    "domains": {
      "test": "recommended"
    },
    "rules": {
      "complexity": {
        "noStaticOnlyClass": "off",
        "noUselessConstructor": "off",
        "noBannedTypes": "warn"
      },
      "correctness": {
        "noUnusedImports": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "style": {
        "useExportType": "off",
        "useImportType": "off",
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "conventions": [
              {
                "formats": ["camelCase", "CONSTANT_CASE", "snake_case", "PascalCase"],
                "selector": {
                  "kind": "objectLiteralMember"
                }
              },
              {
                "formats": ["PascalCase"],
                "selector": {
                  "kind": "typeAlias"
                }
              },
              {
                "formats": ["camelCase", "CONSTANT_CASE", "snake_case"],
                "selector": {
                  "kind": "typeProperty"
                }
              },
              {
                "formats": ["PascalCase"],
                "selector": {
                  "kind": "enum"
                }
              },
              {
                "formats": ["CONSTANT_CASE"],
                "selector": {
                  "kind": "enumMember"
                }
              }
            ],
            "requireAscii": true,
            "strictCase": false
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["tests/**/*.ts", "**/*.spec.ts", "**/*.test.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
