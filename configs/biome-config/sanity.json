{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "linter": {
    "domains": {
      "react": "recommended"
    }
  },
  "overrides": [
    {
      "includes": ["**/sanity.config.ts", "**/sanity.config.js", "**/sanity.cli.ts", "**/sanity.cli.js"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/sanity/**/schema*.{ts,tsx,js,jsx}",
        "**/schemas/**/*.{ts,tsx,js,jsx}",
        "**/studio/**/*.{ts,tsx,js,jsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          },
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
