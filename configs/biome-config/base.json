{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true,
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.nx",
      "!**/.vscode",
      "!**/.idea",
      "!**/.next",
      "!**/.vercel",
      "!**/.turbo",
      "!**/.vinxi",
      "!**/.output",
      "!**/.env",
      "!**/.env.*",
      "!**/dist",
      "!**/build",
      "!**/out",
      "!**/coverage",
      "!**/public",
      "!**/node_modules",
      "!**/storybook-static",
      "!**/CHANGELOG.md",
      "!**/yarn.lock",
      "!**/pnpm-lock.yaml",
      "!**/package-lock.json",
      "!**/*.gen.ts",
      "!**/*.gen.tsx",
      "!**/*.gen.js",
      "!**/routeTree.gen.ts",
      "!**/sanity.types.ts",
      "!**/next-env.d.ts",
      "!**/src/codegen",
      "!**/vite.config.ts.timestamp-*.mjs",
      "!**/configs/**/package.json",
      "!**/packages/**/package.json"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "noDuplicateClasses": "on",
        "organizeImports": "on",
        "recommended": true
      }
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "formatter": {
    "attributePosition": "auto",
    "bracketSpacing": true,
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 120,
    "useEditorconfig": true
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "asNeeded",
      "attributePosition": "auto",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "enabled": true,
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "trailingCommas": "none"
    },
    "linter": {
      "enabled": true
    }
  },
  "linter": {
    "domains": {
      "project": "recommended",
      "types": "recommended"
    },
    "enabled": true,
    "rules": {
      "complexity": {
        "noForEach": "off",
        "recommended": true,
        "useSimplifiedLogicExpression": {
          "fix": "safe",
          "level": "error"
        }
      },
      "correctness": {
        "recommended": true,
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        }
      },
      "nursery": {
        "recommended": true
      },
      "performance": {
        "noAccumulatingSpread": "off",
        "recommended": true
      },
      "recommended": true,
      "security": {
        "recommended": true
      },
      "style": {
        "noDefaultExport": "warn",
        "noNegationElse": {
          "fix": "safe",
          "level": "error"
        },
        "recommended": true,
        "useBlockStatements": {
          "fix": "safe",
          "level": "error"
        },
        "useConst": {
          "fix": "safe",
          "level": "error"
        },
        "useExportType": {
          "fix": "safe",
          "level": "error"
        },
        "useImportType": {
          "fix": "safe",
          "level": "error"
        }
      },
      "suspicious": {
        "noAssignInExpressions": "error",
        "noAsyncPromiseExecutor": "error",
        "noConsole": {
          "level": "error",
          "options": {
            "allow": ["error", "info", "warn"]
          }
        },
        "noEmptyBlockStatements": "off",
        "recommended": true
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.config.ts",
        "**/*.config.*.ts",
        "**/*.config.mts",
        "**/*.config.*.mts",
        "**/*.config.js",
        "**/*.config.*.js",
        "**/*.config.mjs",
        "**/*.config.*.mjs",
        "*.d.ts",
        "src/entry.ts",
        "src/navigation.ts",
        "src/views/**/index.ts",
        "src/views/**/index.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
