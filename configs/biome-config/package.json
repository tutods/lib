{
  "name": "@tutods/biome-config",
  "version": "0.13.3",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Shareable Biome configuration for React, Next.js, NestJS, SolidJS, Tailwind CSS, and Sanity CMS projects. Built for monorepos.",
  "homepage": "https://github.com/tutods/lib/blob/main/configs/biome-config/README.md",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "ssh://git@github.com:tutods/lib.git",
    "directory": "configs/biome-config"
  },
  "keywords": [
    "biome",
    "biomejs",
    "lint",
    "format",
    "react",
    "nextjs",
    "nestjs",
    "solidjs",
    "tailwindcss",
    "sanity",
    "monorepo"
  ],
  "files": [
    "*.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "main": "base.json",
  "exports": {
    ".": "./base.json",
    "./react": "./react.json",
    "./nextjs": "./nextjs.json",
    "./tailwind": "./tailwind.json",
    "./nestjs": "./nestjs.json",
    "./solidjs": "./solidjs.json",
    "./sanity": "./sanity.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2.4.10"
  }
}
