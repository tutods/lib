{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "linter": {
    "domains": {
      "solid": "recommended"
    }
  },
  "overrides": [
    {
      "includes": [
        "**/app.config.ts",
        "**/app.tsx",
        "**/entry-server.tsx",
        "**/entry-client.tsx",
        "**/routes/**/*.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
