{
  "extends": [":dependencyDashboard", ":semanticCommits", "security:openssf-scorecard", "customManagers:biomeVersions"],
  "timezone": "Europe/Lisbon",
  "schedule": ["before 3am every weekday"],
  "labels": ["dependencies", "renovate"],
  "branchConcurrentLimit": 5,
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "dependencyDashboardTitle": "📋 Dependency Dashboard",
  "dependencyDashboardHeader": "This dashboard provides an overview of all dependency updates for this repository.",
  "dependencyDashboardAutoclose": true,
  "dependencyDashboardApproval": true,
  "stopUpdatingLabel": "renovate:stop",
  "rebaseWhen": "conflicted",
  "minimumReleaseAge": "1 day",
  "platformAutomerge": true,
  "osvVulnerabilityAlerts": true,
  "fetchChangeLogs": "pr",
  "rollbackPrs": true,
  "configMigration": true,
  "separateMinorPatch": true,
  "separateMultipleMajor": true,
  "commitMessagePrefix": "chore(deps):",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/", "/(^|/)Dockerfile\\.[^/]*$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s*[A-Z]+\\s+(?<packageName>.*?):(?<currentValue>.*)\\s"
      ],
      "datasourceTemplate": "{{datasource}}",
      "depNameTemplate": "{{depName}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^docker-compose\\.ya?ml$/", "/(^|/)docker-compose\\.[^/]*\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s*image:\\s*(?<packageName>.*?):(?<currentValue>.*)\\s"
      ],
      "datasourceTemplate": "{{datasource}}",
      "depNameTemplate": "{{depName}}"
    }
  ],
  "packageRules": [
    {
      "description": "Major updates - manual review required",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "renovate", "major-update", "priority-medium"],
      "automerge": false
    },
    {
      "description": "Minor and patch updates - auto-merge enabled",
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "renovate", "minor-patch-update", "priority-low"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Security vulnerability fixes — always processed, high priority",
      "matchVulnerabilityAlerts": true,
      "labels": ["dependencies", "renovate", "security", "priority-high"],
      "automerge": true,
      "commitMessagePrefix": "fix(deps):",
      "schedule": ["at any time"]
    },
    {
      "description": "Development dependencies - group minor & patch",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["renovate", "dev-dependencies", "priority-low"],
      "automerge": true,
      "commitMessagePrefix": "chore(deps-dev):",
      "groupName": "Dev dependencies"
    },
    {
      "description": "Major development dependencies - manual review",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["major"],
      "labels": ["renovate", "major-update", "dev-dependencies", "priority-medium"],
      "automerge": false,
      "commitMessagePrefix": "chore(deps-dev):",
      "groupName": "Dev dependencies (major)"
    },
    {
      "description": "GitHub Actions - pin digests, auto-merge minor & patch",
      "matchDatasources": ["github-tags"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "renovate", "github-actions", "priority-medium"],
      "commitMessagePrefix": "ci(deps):",
      "automerge": true,
      "pinDigests": true
    },
    {
      "description": "Major GitHub Actions updates - manual review",
      "matchDatasources": ["github-tags"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "renovate", "major-update", "github-actions", "priority-high"],
      "automerge": false,
      "commitMessagePrefix": "ci(deps):",
      "pinDigests": true
    },
    {
      "description": "Pin digest updates",
      "matchUpdateTypes": ["pinDigest"],
      "labels": ["dependencies", "renovate", "pin-digest", "priority-low"],
      "automerge": true
    },
    {
      "description": "Digest updates",
      "matchUpdateTypes": ["digest"],
      "labels": ["dependencies", "renovate", "digest-update", "priority-low"],
      "automerge": true
    },
    {
      "description": "Docker images - auto-merge minor & patch, pin digests",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "renovate", "docker", "priority-medium"],
      "automerge": true,
      "pinDigests": true,
      "commitMessagePrefix": "chore(docker):"
    },
    {
      "description": "Major Docker image updates - manual review, pin digests",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "renovate", "major-update", "docker", "priority-high"],
      "automerge": false,
      "pinDigests": true,
      "commitMessagePrefix": "chore(docker):"
    },
    {
      "description": "TypeScript and related packages",
      "matchPackageNames": ["typescript", "@types/*", "ts-node", "tsx", "@rslib/*", "@rsbuild/*"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "renovate", "typescript", "priority-medium"],
      "commitMessagePrefix": "chore(typescript):",
      "groupName": "TypeScript packages"
    },
    {
      "description": "Major TypeScript and related packages - manual review",
      "matchPackageNames": ["typescript", "@types/*", "ts-node", "tsx", "@rslib/*", "@rsbuild/*"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "renovate", "major-update", "typescript", "priority-high"],
      "automerge": false,
      "commitMessagePrefix": "chore(typescript):",
      "groupName": "Major TypeScript packages"
    },
    {
      "description": "Biome packages",
      "matchPackageNames": ["@biomejs/biome", "@biomejs/cli-*", "biome"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "renovate", "biome", "priority-medium"],
      "commitMessagePrefix": "chore(biome):",
      "groupName": "Biome packages"
    },
    {
      "description": "Major Biome packages - manual review",
      "matchPackageNames": ["@biomejs/biome", "@biomejs/cli-*", "biome"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "renovate", "major-update", "biome", "priority-high"],
      "automerge": false,
      "commitMessagePrefix": "chore(biome):",
      "groupName": "Major Biome packages"
    },
    {
      "description": "Testing packages",
      "matchPackageNames": ["jest", "vitest", "@testing-library/*", "@jest/*", "jest-*"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "renovate", "testing", "priority-medium"],
      "commitMessagePrefix": "chore(test):",
      "groupName": "Testing packages"
    },
    {
      "description": "Major testing packages - manual review",
      "matchPackageNames": ["jest", "vitest", "@testing-library/*", "@jest/*", "jest-*"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "renovate", "major-update", "testing", "priority-high"],
      "automerge": false,
      "commitMessagePrefix": "chore(test):",
      "groupName": "Major testing packages"
    },
    {
      "description": "Build tools and bundlers",
      "matchPackageNames": ["webpack", "vite", "rollup", "esbuild", "parcel", "@vitejs/*", "@rollup/*", "webpack-*"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "renovate", "build-tools", "priority-medium"],
      "commitMessagePrefix": "chore(build):",
      "groupName": "Build tools"
    },
    {
      "description": "Major build tools and bundlers - manual review",
      "matchPackageNames": ["webpack", "vite", "rollup", "esbuild", "parcel", "@vitejs/*", "@rollup/*", "webpack-*"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "renovate", "major-update", "build-tools", "priority-high"],
      "automerge": false,
      "commitMessagePrefix": "chore(build):",
      "groupName": "Major build tools"
    },
    {
      "description": "Ignore node engine updates in package.json (still allow .nvmrc bumps via the nvm manager)",
      "matchManagers": ["npm"],
      "matchPackageNames": ["node"],
      "enabled": false
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/.next/**", "**/coverage/**"],
  "postUpdateOptions": ["pnpmDedupe"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["on the first day of the month"],
    "commitMessagePrefix": "chore(deps):",
    "automerge": true
  }
}
