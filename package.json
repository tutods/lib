{
  "name": "tutods-lib",
  "private": true,
  "license": "MIT",
  "description": "Monorepo to store my packages.",
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
  "repository": {
    "url": "https://github.com/tutods/lib",
    "type": "git"
  },
  "type": "module",
  "scripts": {
    "prepare": "if [ \"$LEFTHOOK\" != \"0\" ];then lefthook install; fi",
    "build": "nx run-many -t build",
    "release": "nx release",
    "lint": "biome check .",
    "eslint": "nx run-many -t eslint",
    "eslint:fix": "nx run-many -t eslint --fix",
    "lint:fix": "biome check --no-errors-on-unmatched --write .",
    "lint:staged": "biome check --no-errors-on-unmatched --staged .",
    "lint:ci": "biome ci --no-errors-on-unmatched .",
    "renovate:validate": "renovate-config-validator --strict configs/renovate-config/default.json .github/renovate.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@nx/js": "22.7.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.40",
    "@swc/helpers": "~0.5.22",
    "@tutods/biome-config": "workspace:*",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.8",
    "nx": "22.7.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "renovate": "^43.150.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3"
  }
}
