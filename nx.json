{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      {
        "runtime": "node -e 'console.log(`${process.platform}-${process.arch}`)'"
      },
      {
        "runtime": "node --version"
      },
      {
        "runtime": "pnpm --version"
      }
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.spec.tsx",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.test.tsx",
      "!{projectRoot}/**/*.stories.ts",
      "!{projectRoot}/**/*.stories.tsx"
    ]
  },
  "release": {
    "projectsRelationship": "independent",
    "releaseTagPattern": "release/{projectName}/{version}",
    "git": {
      "commit": true,
      "tag": false,
      "push": false,
      "commitMessage": "chore(release): version packages [release]"
    },
    "conventionalCommits": {
      "types": {
        "docs": true,
        "refactor": true,
        "style": true,
        "build": true,
        "revert": true,
        "test": false,
        "ci": true,
        "chore": true
      }
    },
    "version": {
      "conventionalCommits": true
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": true
    },
    "publish": {
      "installIgnoreScripts": true
    }
  },
  "targetDefaults": {
    "build": {
      "inputs": ["production", "^production"],
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json", "{projectRoot}/biome.json"]
    }
  },
  "analytics": false,
  "neverConnectToCloud": true
}
